# --- Next.js (public) ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase — Project Settings → API (same project for URL + key; browsers only)
# Local smoke: after `supabase start` + `supabase db reset`, use the API URL and anon key from `supabase status`
# (typically http://127.0.0.1:54321) so Auth users from seed.sql match `/login`.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# Either variable works (dashboard may label the key publishable vs anon)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_or_publishable_key
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your_key_here
#
# Troubleshooting: 401 on BOTH /auth/v1/token and /auth/v1/signup almost always means
# URL and key are from different projects or the key was truncated. Re-copy both from the
# same Supabase project. With npm run dev, GET http://localhost:3000/api/dev/supabase-auth
# checks whether Auth accepts your key (dev-only route).

# Stripe — Dashboard → Developers → API keys (never expose the secret key to the client)
# Required for artist checkout (new DJ pack submission fees, featured placements) and webhooks.
# On Vercel: Project → Settings → Environment Variables — add all three for Production (and Preview if needed).
STRIPE_SECRET_KEY=sk_live_or_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_or_test_...

# Stripe webhooks — Dashboard → Developers → Webhooks → Signing secret for this endpoint
# Route: POST /api/webhooks/stripe
STRIPE_WEBHOOK_SECRET=whsec_...

# Supabase — Project Settings → API → service_role (server-only; never expose to the browser)
# Used for Stripe webhooks, trusted server jobs, admin DJ pack signed Storage uploads
# (POST /api/admin/tracks/prepare-signed-pack-upload), and the /login "Sign in as" role selector.
# On Vercel: add for Production (and Preview if you test admin uploads there), then redeploy.
# (same project as NEXT_PUBLIC_SUPABASE_URL; never commit real keys).
SUPABASE_SERVICE_ROLE_KEY=

# Optional: show "Sign in as" Artist / DJ / Admin on /login when NODE_ENV=production.
# In `next dev` the selector is on by default. On Vercel, Preview deployments enable it
# automatically; Production needs ENABLE_LOGIN_ROLE_SELECTOR (true / 1 / yes) and a redeploy.
# ENABLE_LOGIN_ROLE_SELECTOR=true

# Optional: HMAC secret for the Backstage "workspace test" escape cookie (admin → artist/dj → admin).
# Required in production when ENABLE_LOGIN_ROLE_SELECTOR is used for workspace testing without `next dev`.
# ADMIN_WORKSPACE_TEST_SECRET=long-random-string

# Optional: VERCEL_URL is set automatically on Vercel for canonical URLs when NEXT_PUBLIC_SITE_URL is unset

# Notifications — transactional email (optional). In-app inbox works without these.
# At least one provider key + matching From address is required to send email.
# RESEND_API_KEY=
# RESEND_FROM_EMAIL="Digital Service Pack <onboarding@resend.dev>"
# SENDGRID_API_KEY=
# SENDGRID_FROM_EMAIL=
# POSTMARK_SERVER_TOKEN=
# POSTMARK_FROM_EMAIL=

# Cron: GET /api/cron/notifications — Authorization: Bearer <secret>
# CRON_SECRET=

# DJ Monitor Pro webhook — POST /api/integrations/dj-monitor-pro/verified-play
# DJ_MONITOR_PRO_WEBHOOK_SECRET=
