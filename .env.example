# --- Next.js (public) ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase — Project Settings → API (use the anon / publishable key in browsers only)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_or_publishable_key

# Stripe — Dashboard → Developers → API keys (never expose the secret key to the client)
STRIPE_SECRET_KEY=sk_live_or_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_or_test_...

# Stripe webhooks — Dashboard → Developers → Webhooks → Signing secret for this endpoint
# Route: POST /api/webhooks/stripe
STRIPE_WEBHOOK_SECRET=whsec_...

# Optional: used by some deployment guides for canonical URLs and emails
# VERCEL_URL is set automatically on Vercel
